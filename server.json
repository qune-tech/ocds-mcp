{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.qune-tech/ocds-mcp",
  "title": "OCDS German Procurement Search",
  "description": "Search and match German public procurement tenders (OCDS) from your local LLM.",
  "version": "0.1.0",
  "websiteUrl": "https://vergabe-dashboard.qune.de",
  "repository": {
    "type": "git",
    "url": "https://github.com/qune-tech/ocds-mcp",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@qune-tech/ocds-mcp",
      "version": "0.3.0",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "OCDS_API_KEY",
          "description": "API key (sk_live_...) from https://vergabe-dashboard.qune.de/app/api-keys",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
